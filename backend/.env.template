# ============================================
# Database Configuration
# ============================================
DATABASE_URL=postgresql+asyncpg://research_user:research_pass_2024@localhost:5432/research_pilot

# ============================================
# Redis Configuration
# ============================================
REDIS_URL=redis://localhost:6379/0

# ============================================
# LLM Provider API Keys
# ============================================
# Add at least one of these API keys

# OpenAI (Uses GPT-4.1-mini)
OPENAI_API_KEY=your_openai_api_key_here

# Google Gemini (Uses 2.5 Flash, with 2.5 Flash Lite and 3.0 Flash Preview as fallbacks)
GEMINI_API_KEY=your_gemini_api_key_here

# Mistral AI (Uses Mistral Large 3)
MISTRAL_API_KEY=your_mistral_api_key_here

# Groq (Uses Llama 3.3 70B)
GROQ_API_KEY=your_groq_api_key_here

# OpenRouter (Optional - uses specified model)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# ============================================
# LLM Model Configuration
# ============================================
# DO NOT CHANGE THESE MODELS - Use exactly as specified

# OpenAI: GPT-4.1-mini
OPENAI_MODEL=gpt-4.1-mini

# Gemini: 2.5 Flash (primary), 2.5 Flash Lite (fallback 1), 3.0 Flash Preview (fallback 2)
GEMINI_MODEL_PRIMARY=gemini-2.5-flash
GEMINI_MODEL_FALLBACK_1=gemini-2.5-flash-lite
GEMINI_MODEL_FALLBACK_2=gemini-3.0-flash-preview

# Mistral: Mistral Large 3
MISTRAL_MODEL=mistral-large-3

# Groq: Llama 3.3 70B
GROQ_MODEL=llama-3.3-70b

# OpenRouter: Specify model if using OpenRouter
# OPENROUTER_MODEL=your_model_here

# ============================================
# Literature Search API Keys
# ============================================
# Semantic Scholar API Key
SEMANTIC_SCHOLAR_API_KEY=ZA5EZsarxE1k2wuAzSpvS6H5R7Go144k2aEjzL4i

# Unpaywall Email
UNPAYWALL_EMAIL=your_email@example.com

# OpenAlex (optional - for polite rate limiting when fetching citation counts)
OPENALEX_EMAIL=your_email@example.com

# ============================================
# Security Configuration
# ============================================
# REQUIRED for production. Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# The server will refuse to start in production without this.
JWT_SECRET_KEY=CHANGE_ME_TO_A_RANDOM_SECRET

# ============================================
# CORS Configuration
# ============================================
# Comma-separated list of allowed frontend origins
# REQUIRED for production — do NOT use wildcard (*)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ============================================
# Application Settings
# ============================================
# Environment (development, production)
ENVIRONMENT=development

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Maximum retries for failed tasks
MAX_TASK_RETRIES=3

# PDF download directory
PDF_TEMP_DIR=/tmp/research_pilot_pdfs

# Export temp directory
EXPORT_TEMP_DIR=/tmp/research_pilot_exports
