# Database Configuration
DATABASE_URL=postgresql+asyncpg://research_user:your_password_here@localhost:5432/research_pilot

# Redis Configuration
REDIS_URL=redis://localhost:6379/0

# File Storage Configuration
# Storage backend: 'local', 's3', or 'r2'
STORAGE_BACKEND=local

# Local storage directory (for local backend)
UPLOAD_DIR=uploads

# S3/R2 Configuration (required for S3/R2 backend)
S3_BUCKET_NAME=your-bucket-name
S3_ACCESS_KEY_ID=your-access-key-id
S3_SECRET_ACCESS_KEY=your-secret-access-key

# AWS S3 specific (omit for R2)
# S3_REGION=us-east-1

# Cloudflare R2 specific (required for R2)
# S3_ENDPOINT_URL=https://<account-id>.r2.cloudflarestorage.com

# File Upload Configuration
MAX_FILE_SIZE=52428800  # 50MB in bytes

# LLM Provider Configuration
# At least one provider is required

# OpenAI
# OPENAI_API_KEY=sk-...

# Google Gemini
# GEMINI_API_KEY=...

# Mistral AI
# MISTRAL_API_KEY=...

# Groq
# GROQ_API_KEY=...

# Authentication Configuration
JWT_SECRET_KEY=your-secret-key-here-change-in-production

# Google OAuth (optional - for production)
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret

# CORS Configuration (comma-separated list)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Server Configuration
HOST=0.0.0.0
PORT=8000
DEBUG=false
